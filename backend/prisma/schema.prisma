// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ======================== 用户 ========================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER")       // ADMIN / USER
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  Session[]
  projects  Project[]
  tasks     Task[]           @relation("Assignee")
  customers Customer[]
  searchResults  SearchResult[]
  savedResearch  SavedResearch[]
  notifications  Notification[]
  conversations  Conversation[]
  memories       UserMemory[]
  greetings      Greeting[]
  profile        Profile?
  preferences    UserPreference?
  goals          Goal[]
  goalProgressLogs GoalProgressLog[]
  timeEntries    TimeEntry[]
  communications Communication[]
  insights       AiInsight[]
}

// ======================== 个人资料 ========================
model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?                       // 个人简介
  birthday    DateTime?                     // 生日
  zodiac      String?                       // 星座
  mbti        String?                       // MBTI 类型
  phone       String?                       // 手机号
  location    String?                       // 所在地
  company     String?                       // 公司/组织
  title       String?                       // 职位头衔
  website     String?                       // 个人网站
  tags        String?                       // 趣味标签（JSON 数组）
  avatarType  String   @default("color")    // color / image
  avatarValue String?                       // 颜色值或图片URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ======================== 会话 ========================
model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  device    String   @default("unknown")   // 设备类型（User-Agent 解析）
  ip        String   @default("unknown")   // 登录 IP 地址
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ======================== 项目 ========================
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("ACTIVE")   // ACTIVE / COMPLETED / ARCHIVED
  startDate   DateTime
  endDate     DateTime?
  budget       Int?                          // 项目预算（分），用 Int 存储避免浮点精度问题，前端 ÷100 显示元
  expenseNote  String?                       // 支出说明
  rewardNote   String?                       // 报酬说明
  type         String?                       // 项目类型标签（如：开发/设计/运营/咨询）
  ownerId      String
  customerId   String?                       // 归属客户
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id])
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tasks       Task[]
  costRecords CostRecord[]
  timeEntries TimeEntry[]
  communications Communication[]
  goals       Goal[]

  @@index([ownerId, status])
  @@index([customerId])
}

// ======================== 任务 ========================
model Task {
  id             String   @id @default(cuid())
  title          String
  description    String?
  status         String   @default("TODO")     // TODO / IN_PROGRESS / DONE / BLOCKED
  priority       String   @default("MEDIUM")   // URGENT / HIGH / MEDIUM / LOW
  estimatedHours Float
  actualHours    Float?
  cost           Int      @default(0)          // 任务花销（分），自动从 CostRecord 聚合
  costNote       String?                       // 花销说明（自动从 CostRecord 汇总）
  blockedReason  String?                       // 阻塞原因（status=BLOCKED 时填写）
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  projectId      String
  assigneeId     String?
  parentId       String?                    // 父任务 ID，null=顶层任务
  progress       Float    @default(0)       // 完成进度 0~100，有子任务时自动计算
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee       User?    @relation("Assignee", fields: [assigneeId], references: [id])
  parent         Task?    @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  children       Task[]   @relation("Subtasks")
  costRecords    CostRecord[]
  timeEntries    TimeEntry[]

  @@index([projectId, status])
  @@index([assigneeId, status])
  @@index([dueDate])
  @@index([parentId])
}

// ======================== 成本记录 ========================
model CostRecord {
  id          String   @id @default(cuid())
  amount      Int                          // 金额（分），用 Int 存储避免浮点精度问题，前端 ÷100 显示元
  category    String                       // LABOR / MATERIAL / OVERHEAD / OTHER
  description String
  date        DateTime
  projectId   String
  taskId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, category])
}

// ======================== 客户 ========================
model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  address   String?
  industry  String?                          // 所属行业
  status    String   @default("ACTIVE")      // ACTIVE / VIP / INACTIVE / LEAD
  notes     String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user          User            @relation(fields: [userId], references: [id])
  projects      Project[]
  communications Communication[]
  goals         Goal[]

  @@index([userId, status])
}

// ======================== 祝福语 ========================
model Greeting {
  id        String   @id @default(cuid())
  content   String                        // 语录内容
  hourStart Int      @default(0)          // 生效起始小时 0-23
  hourEnd   Int      @default(23)         // 生效结束小时 0-23
  isActive  Boolean  @default(true)
  source    String   @default("custom")   // custom / ai / system
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isActive])
}

// ======================== 搜索结果 ========================
model SearchResult {
  id        String   @id @default(cuid())
  query     String
  source    String
  title     String
  content   String
  url       String?
  relevance Float
  saved     Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  savedResearch SavedResearch[]
}

// ======================== 已收藏研究 ========================
model SavedResearch {
  id             String   @id @default(cuid())
  title          String
  summary        String
  content        String
  tags           String                        // JSON 数组字符串，如 ["前端","性能"]
  userId         String
  searchResultId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User          @relation(fields: [userId], references: [id])
  searchResult   SearchResult? @relation(fields: [searchResultId], references: [id], onDelete: SetNull)
}

// ======================== AI 对话记录 ========================
model Conversation {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String          // 会话 ID，同一组对话共享
  role        String          // user / assistant / system / tool
  content     String
  contextType String?
  contextId   String?
  tokenCount  Int?
  toolName    String?         // Function Calling 时记录工具名
  toolResult  String?         // Function Calling 时记录工具返回
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])  // 按用户+会话查询
}

// ======================== 用户长期记忆 ========================
model UserMemory {
  id            String   @id @default(cuid())
  userId        String
  category      String              // PREFERENCE / HABIT / FINANCE / PROJECT / SUMMARY
  key           String
  value         String              // 精简的知识点，一句话
  confidence    Float    @default(0.5)  // 置信度 0~1，多次确认后提升
  source        String   @default("auto")  // auto(对话提炼) / user(用户主动说) / weekly(n8n总结)
  lastAccessedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ======================== 用户偏好 ========================
model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  theme           String   @default("system")     // light / dark / system
  language        String   @default("zh-CN")
  timezone        String   @default("Asia/Shanghai")
  dateFormat      String   @default("YYYY-MM-DD")
  startPage       String   @default("/main/dashboard")
  taskReminder    Boolean  @default(true)
  reminderDays    Int      @default(1)
  projectNotify   Boolean  @default(true)
  systemNotify    Boolean  @default(true)
  emailNotify     Boolean  @default(false)
  dndStart        String?
  dndEnd          String?
  sidebarCollapsed Boolean @default(false)
  pageSize        Int      @default(20)
  defaultView     String   @default("list")
  showStats       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ======================== 系统配置 ========================
model Setting {
  id        String   @id @default(cuid())
  userId    String   @default("system")  // "system" = 全局配置，否则为用户级配置
  category  String                       // AI / NOTIFY / GENERAL 等
  key       String
  value     String
  encrypted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category, key])
}

// ======================== 目标管理 ========================
model Goal {
  id            String   @id @default(cuid())
  userId        String
  title         String
  description   String?
  type          String             // MONTHLY / QUARTERLY / YEARLY
  metricType    String   @default("MILESTONE")  // REVENUE / PROJECT_COUNT / CLIENT_COUNT / HOURS / PERCENTAGE / MILESTONE
  targetValue   Float?                          // 目标值（可为空，MILESTONE 类型不需要）
  currentValue  Float    @default(0)            // 当前进度值
  unit          String?                         // "元" / "个" / "%" / "小时" / null（MILESTONE 类型）
  progressMode  String   @default("AUTO")       // AUTO（自动计算）/ MANUAL（手动记录）/ MILESTONE（里程碑驱动）
  status        String   @default("ACTIVE")     // ACTIVE / COMPLETED / ABANDONED / AT_RISK
  startDate     DateTime
  endDate       DateTime
  projectId     String?                         // 关联项目（可选）
  customerId    String?                         // 关联客户（可选）
  reviewNote    String?                         // 复盘：未达标原因
  nextAction    String?                         // 复盘：改进措施
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  milestones    GoalMilestone[]
  progressLogs  GoalProgressLog[]

  @@index([userId, status])
  @@index([userId, type])
  @@index([userId, startDate, endDate])
  @@index([projectId])
  @@index([customerId])
}

// 目标进度日记 - 记录每次进度变化
model GoalProgressLog {
  id          String   @id @default(cuid())
  goalId      String
  userId      String
  value       Float                          // 本次进度值（增量）
  note        String?                        // 备注说明（如：收到项目A回款）
  date        DateTime                       // 记录日期
  createdAt   DateTime @default(now())
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([userId, date])
}

model GoalMilestone {
  id          String    @id @default(cuid())
  goalId      String
  title       String
  targetValue Float
  completed   Boolean   @default(false)
  completedAt DateTime?
  sortOrder   Int       @default(0)
  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

// ======================== 工时记录 ========================
model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  taskId      String?
  projectId   String?
  hours       Float                        // 工时数（小时），保留 Float 因为 2.5h 等小数合理
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}

// ======================== 沟通记录 ========================
model Communication {
  id          String   @id @default(cuid())
  userId      String
  customerId  String?
  projectId   String?
  type        String             // EMAIL / PHONE / MEETING / CHAT / OTHER
  content     String
  summary     String?
  nextFollowAt DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, customerId])
}

// ======================== AI 洞察 ========================
model AiInsight {
  id          String   @id @default(cuid())
  userId      String
  type        String             // TASK / PROJECT / CUSTOMER / FINANCE / TIME / DECISION
  title       String
  content     String
  severity    String   @default("INFO")  // INFO / WARNING / CRITICAL
  actionable  Boolean  @default(false)
  actionTaken Boolean  @default(false)
  relatedId   String?            // 关联的业务 ID
  createdAt   DateTime @default(now())
  expiresAt   DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, severity])
}

// ======================== 通知 ========================
model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String             // TASK_DUE / COST_ALERT / PROJECT_CHANGE / AI_REPORT / SYSTEM
  title       String
  content     String
  read        Boolean  @default(false)
  relatedId   String?            // 关联的业务 ID（任务/项目等）
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}
