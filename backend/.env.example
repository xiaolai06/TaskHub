# 必填
DATABASE_URL="file:./dev.db"
JWT_SECRET="your-jwt-secret-here"
ENCRYPTION_KEY="your-32-char-encryption-key"

# 服务
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3002

# 安全
COOKIE_SECURE=false
TRUST_PROXY=1
LIMIT_ENABLED=true
CRON_ENABLED=true

# AI（可选）
DEFAULT_AI_PROVIDER=deepseek
DEFAULT_AI_API_KEY=
DEFAULT_AI_BASE_URL=
DEFAULT_AI_MODEL=

# SMTP（可选）
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# n8n（可选）
N8N_BASE_URL=
N8N_WEBHOOK_SECRET=
