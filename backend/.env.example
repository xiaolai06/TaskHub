# ===== 数据库 =====
# 生产环境建议使用绝对路径
DATABASE_URL="file:./dev.db"

# ===== 认证 =====
# 生成方式: openssl rand -base64 48
JWT_SECRET="改成长随机字符串至少32位"
JWT_EXPIRES_IN="7d"

# ===== 加密 =====
# 生成方式: openssl rand -base64 48
ENCRYPTION_KEY="32位AES加密密钥"

# ===== 服务 =====
PORT=3001
NODE_ENV="development"
# 生产环境填实际域名，多个用逗号分隔
FRONTEND_URL="http://localhost:3000"

# ===== 安全 =====
# HTTPS 部署时设为 true
COOKIE_SECURE="false"
# Nginx 反代层数（1 = 信任一层代理）
TRUST_PROXY="1"

# ===== 限频 =====
LIMIT_ENABLED="true"

# ===== 定时任务 =====
CRON_ENABLED="true"

# ===== n8n =====
N8N_BASE_URL="http://localhost:4011"
N8N_WEBHOOK_SECRET=""

# ===== AI =====
DEFAULT_AI_PROVIDER="deepseek"
DEFAULT_AI_API_KEY=""
DEFAULT_AI_BASE_URL=""
DEFAULT_AI_MODEL=""

# ===== 邮件（可选）=====
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ===== 搜索（可选）=====
# 本地部署 SearXNG 搜索引擎时填写
# SEARXNG_URL=http://localhost:8888

# ===== 代理（可选）=====
# 用于访问被墙的搜索源（DuckDuckGo / Google News）
# PROXY_URL=http://127.0.0.1:7890
