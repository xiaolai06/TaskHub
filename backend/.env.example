# ===== 数据库 =====
DATABASE_URL="file:./dev.db"

# ===== 认证 =====
JWT_SECRET="改成长随机字符串至少32位"
JWT_EXPIRES_IN="7d"

# ===== 加密 =====
ENCRYPTION_KEY="32位AES加密密钥"

# ===== 服务 =====
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ===== 限频 =====
LIMIT_ENABLED="true"

# ===== n8n =====
N8N_BASE_URL="http://localhost:4011"
N8N_WEBHOOK_SECRET=""
