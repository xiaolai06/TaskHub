{
  "name": "taskflow-backend",
  "version": "1.0.0",
  "description": "TaskFlow+ 后端 API 服务",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node -e \"const fs=require('fs'),path=require('path');const s=path.join(__dirname,'src','prompts'),d=path.join(__dirname,'dist','prompts');if(fs.existsSync(s)){fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s))if(f.endsWith('.txt'))fs.copyFileSync(path.join(s,f),path.join(d,f))}\"",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "defuddle": "^0.18.1",
    "dotenv": "^16.5.0",
    "duck-duck-scrape": "^2.2.7",
    "express": "^5.1.0",
    "helmet": "^8.2.0",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.3",
    "openai": "^4.104.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.35.1",
    "svg-captcha": "^1.4.0",
    "undici": "^7.27.2",
    "xlsx": "^0.18.5",
    "zod": "^3.25.23"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsdom": "^28.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "docx": "^9.7.1",
    "prisma": "^6.9.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
