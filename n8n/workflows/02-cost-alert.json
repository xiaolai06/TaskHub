{
  "name": "成本预警",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 10 * * *"
            }
          ]
        }
      },
      "name": "每天10点触发",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:3001/api/health",
        "options": {}
      },
      "name": "检查后端连通",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:3001/api/webhooks/notify",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"userId\": \"cmps8qwcj0000u8jog0if8n58\",\n  \"type\": \"COST_ALERT\",\n  \"title\": \"成本预警\",\n  \"content\": \"📊 每日成本检查完成 - {{ $now.format('yyyy-MM-dd HH:mm') }}\"\n}",
        "options": {}
      },
      "name": "创建预警通知",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 0]
    }
  ],
  "connections": {
    "每天10点触发": {
      "main": [
        [
          {
            "node": "检查后端连通",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "检查后端连通": {
      "main": [
        [
          {
            "node": "创建预警通知",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
